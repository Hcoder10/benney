# Copy to .env (gitignored) and fill in real keys.

# Claude — used by the trip planner /reasoning endpoint and the staff
# assistant Haiku card-rewriter. Without it, both fall back to fact-line
# strings (no API calls).
ANTHROPIC_API_KEY=

# AviationStack — used by staff_assistant for live flight ETAs.
# Free tier: 100 req/mo at https://aviationstack.com/signup/free
AVIATIONSTACK_API_KEY=

# Google Maps Directions API — used by staff_assistant for live traffic ETAs.
# Requires billing-enabled project + Directions API enabled.
GOOGLE_MAPS_API_KEY=
